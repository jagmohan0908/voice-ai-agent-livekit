# LiveKit (from LiveKit Cloud)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=voice-agent

# LiveKit SIP Ingress URI (Twilio dials this). From LiveKit Cloud → SIP.
LIVEKIT_SIP_URI=sip:your-ingress@sip.livekit.cloud

# Public URL of this app (for Twilio webhook). e.g. https://your-app.onrender.com
PUBLIC_BASE_URL=

# Twilio
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_PHONE_NUMBER=

# Deepgram (speech-to-text)
DEEPGRAM_API_KEY=

# OpenAI (LLM)
OPENAI_API_KEY=

# ElevenLabs (voice)
ELEVEN_API_KEY=
ELEVEN_VOICE_ID=ODq5zmih8GrVes37Dizd
ELEVEN_MODEL_ID=eleven_flash_v2_5

# Optional: max call length in seconds (default 900 = 15 min)
# MAX_CALL_DURATION_SECONDS=900
