LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Name for this agent worker as it appears in LiveKit Cloud
LIVEKIT_AGENT_NAME=my-inbound-voice-agent

# Deepgram API key for STT (speech-to-text)
DEEPGRAM_API_KEY=

# OpenAI API key for LLM
OPENAI_API_KEY=

# ElevenLabs API key for TTS (text-to-speech)
ELEVEN_API_KEY=

# ElevenLabs voice configuration
ELEVEN_VOICE_ID=ODq5zmih8GrVes37Dizd
ELEVEN_MODEL_ID=eleven_flash_v2_5

# Airtable credentials
AIRTABLE_PAT=
AIRTABLE_BASE_ID=

# Airtable table name for call logs
AIRTABLE_TABLE_NAME=call_logs

# Maximum call duration in seconds (cost protection).
# Example: 900 = 15 minutes. Calls will be ended after this time.
MAX_CALL_DURATION_SECONDS=900

# Twilio webhook / SIP configuration
# Publicly reachable URL that Twilio will POST to for incoming calls.
PUBLIC_BASE_URL=https://your-domain.example.com

# Port that the local Express server listens on for Twilio webhooks
TWILIO_WEBHOOK_PORT=3000

# Twilio auth token used ONLY for validating incoming webhooks.
TWILIO_AUTH_TOKEN=

# Optional: for outbound test (trigger a call from the server to your phone).
# Get Account SID from Twilio Console. TWILIO_PHONE_NUMBER = your Twilio number (e.g. +1234567890).
# TWILIO_ACCOUNT_SID=
# TWILIO_PHONE_NUMBER=

# Optional: LiveKit SIP Outbound Trunk ID (for /outbound-test-sip using sip-participant.json).
# Get from LiveKit Cloud: SIP → Outbound Trunk. Example: ST_xxxxxxxxxxxx
# SIP_OUTBOUND_TRUNK_ID=

# SIP URI to your LiveKit SIP Ingress, which Twilio will dial via TwiML.
# Example (you will get this from LiveKit Cloud SIP Ingress setup):
# sip:your-ingress-id@sip.livekit.cloud
LIVEKIT_SIP_URI=
